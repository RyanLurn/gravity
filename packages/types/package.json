{
  "name": "@gravity/types",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bunx tsdown",
    "build:watch": "bunx tsdown --watch",
    "try": "bun run test/try.ts",
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "devDependencies": {
    "@gravity/eslint-config": "workspace:*",
    "@gravity/typescript-config": "workspace:*",
    "@types/bun": "catalog:types",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
